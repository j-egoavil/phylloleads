# =============================================================================
# PHYLLOLEADS - Variables de Entorno
# =============================================================================

# ============= FRONTEND =============
# URL de la API del backend
VITE_API_URL=http://localhost:8000/api

# Puerto de desarrollo (Vite)
VITE_DEV_PORT=5173

# ============= BACKEND DATABASE =============
# Base de Datos PostgreSQL
DB_HOST=database
DB_PORT=5432
DB_NAME=appdb
DB_USER=postgres
DB_PASSWORD=postgres

# SQLite Fallback (solo si PostgreSQL no está disponible)
APP_DB_PATH=./appdb.sqlite

# ============= BACKEND API =============
# API
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
ENVIRONMENT=development
PYTHONUNBUFFERED=1

# ============= SCRAPER CONFIGURATION =============
# Selenium / Scraper
HEADLESS_MODE=true
BROWSER_HEADLESS=true
CHROME_DRIVER_PATH=/usr/bin/chromedriver
SCRAPER_TIMEOUT=900
SCRAPER_LIMIT=50
SCRAPER_MAX_WORKERS=4

# ============= LOGGING =============
LOG_LEVEL=INFO

# ============= DOCKER PORTS =============
FRONTEND_PORT=3000
BACKEND_PORT=8000
DATABASE_PORT=5432

