# =============================================================================
# PHYLLOLEADS - Variables de Entorno
# =============================================================================

# ============= FRONTEND =============
# URL de la API del backend
VITE_API_URL=http://localhost:8000/api

# Puerto de desarrollo (Vite)
VITE_DEV_PORT=5173

# ============= BACKEND =============
# Base de Datos PostgreSQL
DB_HOST=database
DB_PORT=5432
DB_NAME=phylloleads
DB_USER=postgres
DB_PASSWORD=postgres

# API
API_HOST=0.0.0.0
API_PORT=8000
ENVIRONMENT=development

# Selenium / Scraper
HEADLESS_MODE=true
CHROME_DRIVER_PATH=/usr/bin/chromedriver
SCRAPER_TIMEOUT=30
SCRAPER_MAX_WORKERS=4

# Logging
LOG_LEVEL=INFO

# ============= DOCKER PORTS =============
FRONTEND_PORT=3000
BACKEND_PORT=8000
DATABASE_PORT=5432
