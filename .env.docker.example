# Docker Compose Environment Variables
# Copiar a .env y ajustar según sea necesario

# Base de Datos PostgreSQL
DB_NAME=appdb
DB_USER=postgres
DB_PASSWORD=postgres

# Backend (opcional - hay defaults)
# DB_HOST=database
# DB_PORT=5432
# APP_DB_PATH=/app/appdb.sqlite

# Frontend (opcional - se usan en docker-compose.yml)
# VITE_API_URL=http://backend:8000
# VITE_WS_URL=ws://backend:8000

# Scrapers (opcional)
# HEADLESS=True
# PYTHONUNBUFFERED=1
